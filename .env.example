# ──────────────────────────────────────────────────────────────
# MAS Infrastructure — Environment Variables
# Copy this file to .env and fill in production values.
# ──────────────────────────────────────────────────────────────

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=mas_admin
RABBITMQ_DEFAULT_PASS=changeme_rabbitmq_secret
RABBITMQ_VHOST=/

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=mas_user
POSTGRES_PASSWORD=changeme_postgres_secret
POSTGRES_DB=mas_events
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DSN=postgresql+asyncpg://mas_user:changeme_postgres_secret@postgres:5432/mas_events

# ── FastAPI ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
